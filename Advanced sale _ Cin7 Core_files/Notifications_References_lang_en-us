tr+='</tr>';return tr;};function Notification_SaleTask_ReferencesHeaderBuilder(headers){let tr='<tr>';for(let i=0;i<headers.length;i++){if(headers[i]=='TaskTypeSign'||headers[i]=='TaskID'){continue;}
