
function Notification_Index_OpenReferencesData(messageID){window.CurrentMessageID=messageID;window.CurrentMessageFromPopup=false;const rec=NotificationsStore.getById(window.CurrentMessageID);const referencesJson=rec.get('References');if(referencesJson.indexOf('JSON=')==0){Notification_Index_OpenReferencesJson(referencesJson,true);}
else if(referencesJson.indexOf('References=')==0){Notification_Index_OpenReferencesHtml(referencesJson,true);}}
