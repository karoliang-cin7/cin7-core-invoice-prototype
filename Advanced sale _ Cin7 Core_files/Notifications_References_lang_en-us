function Notification_Production_Operations_ReferencesRowBuilder(data,headers){let tr='';let ProductionOrderID,ProductID;for(var i=0;i<data.length;i++){if(headers[i]=='ProductionOrderID'){ProductionOrderID=data[i];}
else if(headers[i]=='ProductID'){ProductID=data[i];}}
tr+='<tr>';for(var i=0;i<data.length;i++){if(headers[i]=='ProductionOrderID'||headers[i]=='ProductID'){continue;}
if(headers[i]=='ProductionRunNumber'||headers[i]=='ProductionOrderNumber'){tr+=`<td><a href="/ProductionOrder#${ProductionOrderID}"class="mimic_a"target="_blank">${data[i]}</a></td>`;}
