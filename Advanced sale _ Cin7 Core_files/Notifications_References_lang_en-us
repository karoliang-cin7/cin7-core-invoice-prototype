function Notification_ShipStationExportOrders_ReferencesRowBuilder(data,headers){let tr='';let saleRef;let invoiceRef;let ffRef;for(var i=0;i<data.length;i++){if(headers[i]=='SaleRef'){saleRef=data[i];}
else if(headers[i]=='InvoiceRef'){invoiceRef=data[i];}
else if(headers[i]=='FulfillmentRef'){ffRef=data[i];}}
