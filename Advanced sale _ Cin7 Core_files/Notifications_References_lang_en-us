function Notification_Index_ExportToCsv(){if(window.CurrentMessageID&&window.CurrentMessageFromPopup===false){const rec=NotificationsStore.getById(window.CurrentMessageID);let referencesJson=rec.get('References');referencesJson=referencesJson.replace('JSON=','').replaceAll('|nr|','; ');document.getElementById('referencesJsonData').value=referencesJson;document.getElementById('frmDownloadReferencesData').submit();}
else if(window.CurrentMessageID&&window.CurrentMessageFromPopup===true){Notification_Index_ExportToCsvPopup(window.CurrentMessageID);}
else if(window.CurrentMessageReference&&window.CurrentMessageReference.indexOf('JSON=')>-1){const referencesJson=window.CurrentMessageReference.replace('JSON=','').replaceAll('|nr|','; ');document.getElementById('referencesJsonData').value=referencesJson;document.getElementById('frmDownloadReferencesData').submit();}}
function Notification_Index_ProcessExportToCsvButton(fileName){switch(fileName){case'SalesProcessingErrors.csv':$('#Notification_Index_ExportToCsvButton').hide();return;default:$('#Notification_Index_ExportToCsvButton').show();return;}}
function Notification_Index_BuildReferencesRow(data,headers,recordType,idIndex){switch(recordType){case'saletask':return Notification_SaleTask_ReferencesRowBuilder(data,headers,idIndex);case'productdiscount':return Notification_SaleDiscount_ReferencesRowBuilder(data,headers,idIndex);case'saleshipment':return Notification_SaleShipment_ReferencesRowBuilder(data,headers,idIndex);case'customer':return Notification_Customer_ReferencesRowBuilder(data,headers,idIndex);case'product':return Notification_ChangeInPrice_ReferencesRowBuilder(data,headers,idIndex);case'productionOrder_RelatedTasks':return Notification_Production_RelatedTasks_ReferencesRowBuilder(data,headers);case'productionOrder_Operations':return Notification_Production_Operations_ReferencesRowBuilder(data,headers);case'shipstationexportorders':return Notification_ShipStationExportOrders_ReferencesRowBuilder(data,headers);default:return Notification_Index_ReferencesRowBuilder(data);}}
function Notification_Index_BuildReferencesHeader(headers,recordType){switch(recordType){case'saletask':return Notification_SaleTask_ReferencesHeaderBuilder(headers);case'productdiscount':return Notification_SaleDiscount_ReferencesHeaderBuilder(headers);case'saleshipment':return Notification_SaleShipment_ReferencesHeaderBuilder(headers);case'customer':return Notification_Customer_ReferencesHeaderBuilder(headers);case'product':return Notification_ChangeInPrice_ReferencesHeaderBuilder(headers);case'productionOrder_RelatedTasks':return Notification_Production_RelatedTasks_HeaderBuilder(headers);case'productionOrder_Operations':return Notification_Production_Operations_HeaderBuilder(headers);case'shipstationexportorders':return Notification_ShipStationExportOrders_ReferencesHeaderBuilder(headers);default:return Notification_Index_ReferencesHeaderBuilder(headers);}}
function Notification_Index_ReferencesHeaderBuilder(headers){let tr='<tr>';for(let i=0;i<headers.length;i++){tr+=`<th>${headers[i]}</th>`;}
tr+='</tr>';return tr;}
