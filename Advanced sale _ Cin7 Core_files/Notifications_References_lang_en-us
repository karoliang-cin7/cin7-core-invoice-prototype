Notification_Index_ProcessExportToCsvButton(reference.FileName);$('#tblReferencesTable tbody').html(tableData);$('#divReferencesData').modal('show');if(mostTop===true){if(window.is2019design===true){$('#divReferencesData').addClass('mostTop');$($('#divReferencesData').data('bs.modal').$backdrop).addClass('mostTop');}
else{$('#divReferencesData').parent().addClass('mostTop');const $backdrop1=$('#divReferencesData').data('modal').$backdrop;$backdrop1.addClass('mostTop');}}
else if(window.is2019design===true){$('#divReferencesData').removeClass('mostTop');$($('#divReferencesData').data('bs.modal')._backdrop).removeClass('mostTop');}
else{$('#divReferencesData').parent().removeClass('mostTop');const $backdrop2=$('#divReferencesData').data('modal').$backdrop;$backdrop2.removeClass('mostTop');}}
