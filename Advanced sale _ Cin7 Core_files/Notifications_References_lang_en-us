else{tr+=`<td>${data[i]}</td>`;}}
tr+='</tr>';return tr;};function Notification_SaleShipment_ReferencesHeaderBuilder(headers){let tr='<tr>';for(let i=0;i<headers.length;i++){if(headers[i]=='Carrier'){tr+='<th>Carrier</th>';}
