else{tr+=`<td>${data[i]}</td>`;}}
tr+='</tr>';return tr;};function Notification_Production_Operations_HeaderBuilder(headers){let tr='<tr>';for(let i=0;i<headers.length;i++){if(headers[i]=='ProductionOrderID'||headers[i]=='ProductID'){continue;}
