/* Put your IE-only styles here. Works for IS 10 & IE 11*/
@media screen and (-ms-high-contrast: none) {
    
    .form-label-inside .form-control > input:-ms-input-placeholder,
    .form-label-inside .form-control > textarea:-ms-input-placeholder {
        text-indent: inherit !important;
        color: inherit !important;
    }
    .form-label-inside .form-control > input:not([type='submit']):not([type='button']):not([type='radio']):not([type='checkbox']),
    .form-label-inside .form-control .bootstrap-select .dropdown-toggle,
    .form-label-inside .form-control .bootstrap-select.edited .dropdown-toggle,
    .form-label-inside .form-control > textarea {
        padding: 8px 8px 8px 16px;
       
    }
    .form-label-inside .form-control > textarea + label {
        display: none;
    }
    :-ms-input-placeholder {
        text-indent: 0 !important;
    }
    ::-ms-clear,
    ::-ms-reveal {
        display: none!important;
    }
    .form-control input[type='checkbox']:not(.toggle) + label::after {
        margin-left: -2px !important;
    }
    .x-form-type-checkbox .x-form-item-body::after {
        margin-left: -3px !important;
    }
    .form-control-checkbox {
        height:60px;
        vertical-align: middle;
    }
    .form-label-inside .form-control .bootstrap-select + label {
        display: none;
    }
    table.x-form-item .x-form-item-body .x-trigger-cell .x-form-trigger {
        vertical-align: middle;
        display: table-cell;
        position:relative!important
    }
    table.x-form-item .x-form-item-body .x-trigger-cell .x-form-trigger:after {
        position:relative!important;
        bottom:-1px;
        right:-1px;
    }
    .page-bar .grid-row .grid-col-4 .form-control.form-control-checkbox > div {
        width:16px;
    }
    .grid-row .grid-col-4 .form-control > div {
        width:100%
    }
    .btn.nopadding {
        padding:0
    }
    .btn:not(.btn-small) {
        height:40px;
    }
    /*
    table.x-form-item .x-form-item-body > table {
        height:40px;  // brake editor
    }*/
    .x-grid-checkheader:after {
        margin-left: -2px
    }

    .btn.btn-count {
        overflow: visible;
    }

    .dr-warning .alert {
        min-height:100%;
        padding-top:18px;
        padding-bottom:18px;
    }

    .calendar-form .grid-col-6,
    .calendar-form .col-md-6 {
        width: 50%;
        flex-basis: inherit;
    }

    .calendar-form .x-datepicker.embedded-datepicker > div:nth-child(1) {
        box-shadow: inherit;
        border-radius: inherit;
    }

    .page-toolbar .dashboard-filter-quick button.filter-header {
        margin-bottom: inherit;
        margin-top: -5px;
    }

    .form-control input[type='checkbox'].toggle {
        border:none;
    }
}

